#!/bin/sh

set -e

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR -- '*.cs' '*.csproj' '*.sln' '*.props' '*.targets')"

if [ -z "$staged_files" ]; then
  exit 0
fi

printf '%s\n' "$staged_files" | while IFS= read -r file; do
  [ -z "$file" ] && continue
  dotnet csharpier format "$file"
  git add -- "$file"
done

printf '%s\n' "$staged_files" | while IFS= read -r file; do
  [ -z "$file" ] && continue
  dotnet csharpier check "$file"
done