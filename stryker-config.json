{
  "stryker-config": {
    "project": "Shopizy.Domain.csproj",
    "test-projects": [
      "tests/Shopizy.Domain.UnitTests/Shopizy.Domain.UnitTests.csproj"
    ],
    "reporters": [
      "html",
      "progress",
      "cleartext"
    ],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 50
    },
    "mutation-level": "Standard",
    "mutate": [
      "src/Shopizy.Domain/**/*.cs",
      "!src/Shopizy.Domain/**/Migrations/*.cs"
    ],
    "concurrency": 4
  }
}
